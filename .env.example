# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Backend Base URL (for emulator/device/testing)
# Use http://10.0.2.2:3000/ inside the Android Emulator
# Use http://localhost:3000/ for local server/Robolectric tests
# Use your production Vercel/Render URL in production (e.g. https://redimain.vercel.app/)
BACKEND_URL=http://localhost:3000/

# SMTP Configuration (Required for real email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password_or_token
SMTP_SENDER="REDIMAIN - Sistema Táctico <your_email@example.com>"

# Cloudinary (Almacenamiento de fotos y archivos adjuntos - Plan gratuito)
# Obtener en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
# Crear en: Cloudinary Console → Settings → Upload → Upload presets → Add unsigned preset
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name
